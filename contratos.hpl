    <name>Sep_numerico</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>REGEXP</function>
        <leftvalue>num_contrato</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
        <value>
          <isnull>N</isnull>
          <length>-1</length>
          <name>constant</name>
          <precision>-1</precision>
          <text>^[0-9.]+$</text>
          <type>String</type>
        </value>
      </condition>
    </compare>
    <send_false_to>nao_numerico</send_false_to>
    <send_true_to>red_duplicidade</send_true_to>
